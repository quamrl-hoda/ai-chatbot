# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# ── Google / HuggingFace (optional) ───────────────────────────────────────────
GOOGLE_API_KEY=
HF_TOKEN=

# ── LangSmith tracing (optional) ──────────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=ai-chatbot

# ── Database ──────────────────────────────────────────────────────────────────
# Development (SQLite):
DATABASE_URL=sqlite:///./database/chatbot.db
# Production (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/chatbot

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
# APP_API_KEY=           # Uncomment to enable API-key auth
CORS_ORIGINS=["*"]      # Restrict in production, e.g. ["https://yourfrontend.com"]
